# Senha do painel admin (backdoor) — defina uma senha forte, só sua.
ADMIN_PASSWORD=""

# (opcional) trocar o modelo; padrão é o Q4 (mais leve/rápido)
# Modelo LLM (arquivo .gguf dentro de ../models). Padrao: Llama 3.1 8B.
# Para o Qwen2.5-14B, baixe o .gguf e descomente a linha abaixo:
# MODEL_FILE="Qwen2.5-14B-Instruct-Q4_K_M.gguf"

# Ajustes de VRAM (descomente e reduza SE faltar memoria na GPU):
# N_CTX="6144"
# N_GPU_LAYERS="40"

# Modelo Gemini (nuvem) — opcional. Habilita a opcao "Gemini" em Configuracoes > Modelos.
# A chave NUNCA vai para o codigo/Git: fica so aqui. Deixe vazio para desabilitar o Gemini.
GEMINI_API_KEY=""
# (opcional) trocar o modelo Gemini; padrao: gemini-2.5-flash-lite
# GEMINI_MODEL="gemini-2.5-flash-lite"
